{
  "name": "cog",
  "description": "The Cog CLI — wires the agent, providers, and TUI together. Ships the `cog` binary.",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "cog": "./bin/cli.js"
  },
  "keywords": [],
  "author": "connorlittleton",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "agent": "workspace:*",
    "providers": "workspace:*",
    "tui": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.8.0"
  }
}
